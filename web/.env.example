# NAura web — backend integration endpoints
# Copy to .env and adjust if your backends run elsewhere.

# EVM Privacy-Pools bridge (pp-bridge/server.js)
VITE_BRIDGE_URL=http://localhost:3001

# Solana AI swarm WebSocket (backend/agent_swarm.py)
VITE_SWARM_URL=ws://localhost:8000/events

# Naura EVM escrow (evm/contracts/NauraEscrow.sol) — deployed address on Sepolia.
# Leave empty to keep the simulated funding flow; set it to enable real on-chain escrow.
VITE_ESCROW_ADDRESS=
