# NAura PP Bridge — Environment Configuration
# Copy this file to .env and fill in your values

# Sepolia RPC endpoint (Alchemy, Infura, or public)
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Donor demo wallet private key (Sepolia testnet only — NEVER use mainnet keys)
# Fund this from https://sepoliafaucet.com or https://faucets.chain.link/sepolia
DONOR_PRIVATE_KEY=0x_YOUR_DONOR_PRIVATE_KEY_HERE

# NAura escrow wallet private key (receives private transfers from donors)
ESCROW_PRIVATE_KEY=0x_YOUR_ESCROW_PRIVATE_KEY_HERE

# PP v2 SDK configuration
ASP_URL=https://api-dev.0xbow.io
RELAYER_URL=https://relayer-v2-staging-149184580131.us-east1.run.app
RELAYER_ADDRESS=0x4Ba5fF376865b370790A56276C63e7984DCFf1f7

# Server port
PORT=3001
